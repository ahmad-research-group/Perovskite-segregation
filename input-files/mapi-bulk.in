&CONTROL
                       title = 'mapi.relax'
                 calculation = 'relax'
                restart_mode = 'from_scratch'
                      outdir = './relax-test-mapi-unit-cubic'
                      prefix = 'mapis222-pristine'
                     disk_io = 'low'
                   verbosity = 'default'
               etot_conv_thr = 1.0e-4
               forc_conv_thr = 1.0e-3
                       nstep = 400
                     tstress = .true.
                     tprnfor = .true.
!                 max_seconds = 86300
!            dipfield =  true, tefield =   true
/
&SYSTEM
                        ibrav=0
                        nat =12 , ntyp = 5
                     ecutwfc = 80
!                       nbnd = 138
                       tot_charge = 0
                    vdw_corr = 'DFT-D3'
!                 edir = 3, emaxpos = 0.95, eamp = 0.0, eopreg = 0.05
!                 nspin = 2, starting_magnetization(4) = 0.25
!       noncolin = .true., lspinorb = .true., starting_magnetization(4) = 0.
!       nbnd = 28
                occupations = 'smearing', smearing = 'gaussian', degauss = 0.002
/
&ELECTRONS
            electron_maxstep = 200
                    conv_thr = 1.0D-8
              diago_thr_init = 1e-4
                 startingpot = 'atomic'
                 startingwfc = 'atomic+random'
                 mixing_mode = 'plain'
                 mixing_beta = 0.3
                 mixing_ndim = 8
             diagonalization = 'david'
/
&IONS
                ion_dynamics = 'bfgs'
/


ATOMIC_SPECIES
C  12.0110000000  C-nc-sr-04_pbe_standard.upf
Pb  207.2000000000  Pb-nc-sr-04_pbe_stringent.upf
I   126.9040000000  I-nc-sr-04_pbe_standard.upf
N  14.0067000000000  N-nc-sr-04_pbe_standard.upf
H  1.0078400000000  H-nc-sr-04_pbe_standard.upf


