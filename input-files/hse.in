 &CONTROL
                       title = 'mapi.cif'
                 calculation = 'scf'
                restart_mode = 'from_scratch'
                      outdir = './relax-test'
                      prefix = 'mapic222-defect'
                     disk_io = 'low'
                   verbosity = 'default'
               etot_conv_thr = 1.0e-4
               forc_conv_thr = 1.0e-3
                       nstep = 400
                     tstress = .true.
                     tprnfor = .true.
!	          max_seconds = 86300
!            dipfield =  true, tefield =   true		
/
&SYSTEM
                       ibrav = 0
!		       A=12.311992990000
                         nat = 24, ntyp = 6
                     ecutwfc = 80
		     ecutfock = 80
                        nbnd = 210
		       tot_charge = 0
                    vdw_corr = 'DFT-D3'
!		  edir = 3, emaxpos = 0.95, eamp = 0.0, eopreg = 0.05
!		  nspin = 2, starting_magnetization(4) = 0.25
	input_dft='hse', nqx1 = 3, nqx2 = 3, nqx3 = 3,
	screening_parameter = 0.106 
	x_gamma_extrapolation = .true., exxdiv_treatment = 'gygi-baldereschi', exx_fraction = 0.43
	noncolin = .true., lspinorb = .true., starting_magnetization(4) = 0.		   
!	nbnd = 28
!		occupations = 'smearing', smearing = 'gaussian', degauss = 0.002
!		occupations = 'fixed'
/
&ELECTRONS
            electron_maxstep = 200
                    conv_thr = 1.0D-8
              diago_thr_init = 1e-6
                 startingpot = 'atomic'
                 startingwfc = 'atomic+random'
                 mixing_mode = 'plain'
                 mixing_beta = 0.3
                 mixing_ndim = 8
             diagonalization = 'david'
/
&IONS
                ion_dynamics = 'bfgs'
/



ATOMIC_SPECIES
